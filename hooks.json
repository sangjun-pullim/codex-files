{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh /Users/pullim/.codex/hooks/block-env-read.sh"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-env-commit.sh"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ] && [ -r '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ] && [ -x '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/pullim/.orca/agent-hooks/claude-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ] && [ -r '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ] && [ -x '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/pullim/.orca/agent-hooks/claude-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ] && [ -r '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ] && [ -x '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/pullim/.orca/agent-hooks/claude-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ] && [ -r '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ] && [ -x '/Users/pullim/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/pullim/.orca/agent-hooks/claude-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
